# AI Gateway Client 配置

# 服務端口
PORT=3006

# AI Gateway 服務地址（不包含路徑）
GATEWAY_URL=https://www.herelai.fun

# AI Gateway API 路徑
GATEWAY_API_PATH=/api/query

# 應用 ID
APP_ID=ai-chat-client

# 啟用流式響應（true/false）
ENABLE_STREAM=true

# 最大重試次數
MAX_RETRIES=3

# 重試延遲（ms）
RETRY_DELAY=1000

# Rate Limiting 窗口（ms）
RATE_LIMIT_WINDOW=60000

# Rate Limiting 最大請求數
RATE_LIMIT_MAX=60
