# AI Gateway Client 配置範例
PORT=3006
GATEWAY_URL=https://your-host/ws/05-ai-gateway
GATEWAY_API_PATH=/api/query
APP_ID=ai-chat-client
MAX_RETRIES=2
RETRY_DELAY=1000
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30
ADMIN_TOKEN=生成一個安全的隨機 token (openssl rand -hex 32)
CORS_ORIGINS=https://your-frontend.com
MAX_BATCH_SIZE=5
MAX_MESSAGE_LENGTH=10000
